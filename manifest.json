    },
    "codex": {
      "entry": "platforms/codex/ask-five-skill.md",
      "type": "single-file",
      "routing": "rule-based",
      "install": "Copy platforms/codex/ask-five-skill.md to ~/.codex/skills/ask-five-skill.md"
    },
    "claude-code": {
      "entry": "platforms/claude-code/ask-five/ask-five.md",
      "type": "multi-file",
      "routing": "dynamic",
      "install": "Copy platforms/claude-code/ask-five/ to your project's .claude/ask-five/"
    }
  },
  "expertsCount": 25,
  "defaultEnabled": false,
  "repository": "https://github.com/nico-zhuang/ask-five-skill"
